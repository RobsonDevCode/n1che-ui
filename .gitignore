# ============================================================
# Xcode
# ============================================================

# User-specific Xcode settings (breakpoints, schemes, window layout)
xcuserdata/
*.xcuserstate
*.xcuserdatad/

# Build products
build/
DerivedData/
*.xcarchive
*.ipa
*.dSYM.zip
*.dSYM

# Playgrounds
timeline.xctimeline
playground.xcworkspace

# Temporary Xcode files
*.moved-aside
*.hmap

# Xcode 8+: simulators, CoreData, device logs
*.xcscmblueprint
*.xccheckout

# ============================================================
# Swift Package Manager
# ============================================================

.build/
.swiftpm/
# Uncomment the line below if you do NOT want to commit Package.resolved
# Package.resolved

# ============================================================
# CocoaPods (if ever adopted)
# ============================================================

Pods/
Podfile.lock
*.xcworkspace
# Keep the project's own .xcworkspace if generated by Xcode (not CocoaPods)
!*.xcodeproj/project.xcworkspace

# ============================================================
# Environment & Configuration files
# ============================================================

# Xcconfig files hold API keys and environment-specific values — never commit
*.xcconfig
Config.xcconfig
*.env
.env
.env.*
.env*.local

# ============================================================
# API keys, secrets, credentials
# ============================================================

*secret*
*Secret*
*SECRET*
*key*
*Key*
*KEY*
*credentials*
*Credentials*
*CREDENTIALS*
*.pem
*.p8
*.p12
*.jks
*.mobileprovision
*.certSigningRequest
AuthKey_*.p8
GoogleService-Info.plist
amplifyconfiguration.json
awsconfiguration.json

# ============================================================
# Sentry
# ============================================================

# Sentry upload artefacts / debug symbol uploads
.sentryclirc
sentry-debug-meta.plist

# ============================================================
# AWS Amplify generated files
# ============================================================

amplify/
#amplify-build-config.json
AmplifyConfig/
amplifyconfiguration.dart

# ============================================================
# macOS system files
# ============================================================

.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db

# ============================================================
# IDE / Editor files
# ============================================================

.idea/
*.swp
*.swo
*~
.vscode/

# ============================================================
# Node / npm (tooling only, not app code)
# ============================================================

node_modules/
npm-debug.*
yarn-debug.*
yarn-error.*
*.tsbuildinfo

# ============================================================
# Miscellaneous
# ============================================================

*.orig
*.log
*.bak
.tags
